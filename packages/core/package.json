{
  "name": "@v-kit/core",
  "version": "0.0.2",
  "description": "Shared VS Code Marketplace logic for vtools (parse, resolve, build download URL).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stekovinbranturry/vtools.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsgo --noEmit",
    "test": "ava",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@typescript/native-preview": "latest",
    "ava": "^5.2.0",
    "ts-node": "^10.9.1",
    "tsdown": "^0.9.0",
    "typescript": "5.9.2"
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "nodeArguments": [
      "--loader=ts-node/esm"
    ]
  }
}
