{
  "name": "@ztools/extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A Chrome extension that replaces the new tab page with a developer tools dashboard.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check-types": "tsc -b --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ztools/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/chrome": "^0.0.279",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
