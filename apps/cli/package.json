{
  "name": "@ztools/cli",
  "version": "0.0.0",
  "license": "MIT",
  "bin": {
    "ztools": "dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsgo --noEmit",
    "test": "ava"
  },
  "files": ["dist"],
  "dependencies": {
    "@ztools/core": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "ink": "^4.1.0",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "meow": "^11.0.0",
    "ora": "^9.4.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^3.0.1",
    "@types/react": "^18.0.32",
    "@typescript/native-preview": "latest",
    "@vdemedes/prettier-config": "^2.0.1",
    "ava": "^5.2.0",
    "ink-testing-library": "^3.0.0",
    "prettier": "^2.8.7",
    "ts-node": "^10.9.1",
    "tsdown": "^0.9.0",
    "typescript": "^5.0.3"
  },
  "ava": {
    "extensions": {"ts": "module", "tsx": "module"},
    "nodeArguments": ["--loader=ts-node/esm"]
  },
  "prettier": "@vdemedes/prettier-config"
}
