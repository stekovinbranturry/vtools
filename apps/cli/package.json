{
  "name": "@v-kit/cli",
  "version": "0.2.0",
  "description": "Ink-based terminal app for downloading VS Code extensions (.vsix). Binary: vkit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stekovinbranturry/vkit.git",
    "directory": "apps/cli"
  },
  "bin": {
    "vkit": "dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsgo --noEmit",
    "test": "ava",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "readme.md"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@v-kit/core": "workspace:*",
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "fkill": "^10.0.3",
    "ink": "^7.1.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^11.0.0",
    "ora": "^9.4.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "update-notifier": "^7.3.1",
    "which": "^7.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "^3.0.1",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/update-notifier": "^6.0.8",
    "@types/which": "^3.0.4",
    "@typescript/native-preview": "latest",
    "@vdemedes/prettier-config": "^2.0.1",
    "ava": "^5.2.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^2.8.7",
    "ts-node": "^10.9.1",
    "tsdown": "^0.9.0",
    "typescript": "^5.0.3"
  },
  "ava": {
    "extensions": {
      "ts": "module",
      "tsx": "module"
    },
    "nodeArguments": [
      "--loader=ts-node/esm"
    ]
  },
  "prettier": "@vdemedes/prettier-config"
}
